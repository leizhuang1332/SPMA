# SPMA 环境变量配置
# 复制此文件为 .env 后填写实际值: cp .env.example .env

# ============================================================
# 必填: LLM API 密钥
# ============================================================
# DeepSeek V4 (推荐，默认 provider)
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx

# Anthropic Claude (备选 provider)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
ANTHROPIC_BASE_URL=https://api.anthropic.com

# OpenAI (备选 provider)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx

# ============================================================
# 数据库 (docker compose 默认值, 无需修改)
# ============================================================
POSTGRES_USER=spma
POSTGRES_PASSWORD=spma
POSTGRES_DB=spma
PGVECTOR_URL=postgresql://spma:spma@postgres:5432/spma_vector
POSTGRES_READONLY_URL=postgresql://spma:spma@postgres:5432/spma

# ============================================================
# Redis (docker compose 默认值, 无需修改)
# ============================================================
REDIS_URL=redis://redis:6379/0

# ============================================================
# Elasticsearch (启用 --profile es 时需要)
# ============================================================
ES_HOST=http://elasticsearch:9200
ES_USER=elastic
ES_PASSWORD=elastic

# ============================================================
# vLLM 本地推理 (启用 --profile gpu 时需要)
# ============================================================
VLLM_BASE_URL=http://vllm:8000/v1
VLLM_EMBEDDING_MODEL=BAAI/bge-m3
VLLM_LLM_MODEL=Qwen/Qwen3-8B

# ============================================================
# 可观测性 (启用 --profile observability 时需要)
# ============================================================
# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=spma

# Prometheus (无需配置, 自动抓取 /metrics)

# ============================================================
# Langfuse LLM 追踪 (启用 --profile langfuse 时需要)
# ============================================================
LANGFUSE_HOST=http://langfuse-server:3000
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxx

# ============================================================
# Feature Flags 配置路径 (可选)
# ============================================================
# SPMA_FEATURE_FLAGS_PATH=/app/config/feature_flags.yaml

# ============================================================
# 服务端口暴露 (本地开发用)
# ============================================================
API_PORT=8000
AGENT_PORT=9000
ES_PORT=9200
REDIS_PORT=6379
POSTGRES_PORT=5432
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318
PROMETHEUS_PORT=9090
LANGFUSE_PORT=3000
